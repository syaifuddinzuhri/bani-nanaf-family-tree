rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Family members: anyone can read, only authenticated users can write
    match /members/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deceased members: anyone can read, only authenticated users can write
    match /deceased_members/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Agendas: anyone can read, only authenticated users can write
    match /agendas/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
